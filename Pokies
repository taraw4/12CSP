# Pokies

# Get randomiser
import random

# Create symbols list
symbols = ["7", "$", "*", "#"]

# Generate Grid
grid = []

# Row runs 3 times
for row in range(3):
    row_list = []

# Every column choose random symbol and add to row
    for column in range(3):
        item = random.choice(symbols)
        row_list.append(item)
        
# Add new row to grid
    grid.append(row_list)

# Every grid print on new line 
for row in grid:
    print(row)


    

